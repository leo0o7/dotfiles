#!/bin/bash

if [ $# -ne 1 ]; then
  echo "Usage: $0 [folder]"
  exit 1
fi

folder="$1"

if [ ! -d "$folder" ]; then
  echo "'$folder' is not a directory."
  exit 2
fi

# Iterate recursively over all files
find "$folder" -type f | while read -r file; do
  # Get creation time (%w). If not available, skip.
  ctime=$(gstat -c %w "$file")
  if [ "$ctime" = "-" ]; then
    echo "Creation time not available for $file, skipping..."
    continue
  fi

  # Strip nanoseconds and timezone for touch
  ctime_clean=$(echo "$ctime" | awk '{print $1 " " $2}')

  # Update modification time
  touch -m -d "$ctime_clean" "$file"
  echo "Modification time of '$file' set to creation time: $ctime_clean"
done

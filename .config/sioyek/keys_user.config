# Vim-style half-page scrolling
screen_down <C-d>
screen_up <C-u>
prev_state <C-o>
toggle_titlebar <C-w>
next_state <C-i>
zoom_in K
zoom_out J

move_left l
move_right h

# Toggle dark mode with 'i' (for "invert")
toggle_dark_mode i
toggle_custom_color c
reload_config r
helper_window


fit_to_page_width s

add_highlight H
delete_highlight L
